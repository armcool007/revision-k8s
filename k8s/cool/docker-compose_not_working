version: "3"
services:
  db:
    networks:
      - testing
    container_name: db_app
    image: mysql
    restart: always
    environment:
      MYSQL_ROOT_PASSWORD: root
        #MYSQL_USER: root
        #MYSQL_PASSWORD: root
      MYSQL_DATABASE: testdb
    ports:
      - "3306"
  app:
    networks:
      - testing
    container_name: java-app
      #image: eclipse-temurin:17  #it you dont have the dockerfile
    build: .
    depends_on:
      - db
    ports:
      - "8080:8080"
    environment:
      #      SPRING_DATASOURCE_URL: jdbc:mysql://db:3306/testdb
      SPRING_DATASOURCE_URL: jdbc:mysql://db:3306/testdb?allowPublicKeyRetrieval=true&useSSL=false&serverTimezone=UTC

      SPRING_DATASOURCE_USERNAME: root
      SPRING_DATASOURCE_PASSWORD: root
      restart: on-failure
networks:
  testing:

