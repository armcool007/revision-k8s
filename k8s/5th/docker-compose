app:
  build: .
  ports:
    - "8080:8080"
  depends_on:
    db:
      condition: service_healthy
  environment:
    SPRING_PROFILES_ACTIVE: docker

db:
  image: mysql:8.0
  environment:
    MYSQL_ROOT_PASSWORD: rootpass123
    MYSQL_DATABASE: business_db
    MYSQL_USER: business_user
    MYSQL_PASSWORD: root
  ports:
    - "3306:3306"
  volumes:
    - mysql_data:/var/lib/mysql
  healthcheck:
    test: ["CMD", "mysqladmin", "ping", "-h", "localhost"]
    timeout: 20s
    retries: 10
